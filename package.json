{
  "name": "@elora-cloud/elora-unplugin-vue-components",
  "type": "module",
  "version": "1.0.17",
  "private": false,
  "packageManager": "pnpm@10.20.0",
  "description": "unplugin-vue-components for elora",
  "author": "Elora",
  "license": "ISC",
  "homepage": "https://github.com/Elora-Cloud/elora-unplugin-vue-components/blob/master/README.md",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Elora-Cloud/elora-unplugin-vue-components.git"
  },
  "bugs": {
    "url": "https://github.com/Elora-Cloud/elora-unplugin-vue-components/issues"
  },
  "keywords": [
    "unplugin-vue-components",
    "unplugin-auto-import",
    "element-plus",
    "@elora-cloud/elora-plus"
  ],
  "exports": {
    ".": {
      "types": "./es/index.d.ts",
      "import": "./es/index.mjs",
      "require": "./lib/index.cjs"
    },
    "./es": {
      "types": "./es/index.d.ts",
      "import": "./es/index.mjs"
    },
    "./lib": {
      "types": "./lib/index.d.ts",
      "require": "./lib/index.cjs"
    },
    "./es/*.mjs": {
      "types": "./es/*.d.ts",
      "import": "./es/*.mjs"
    },
    "./es/*": {
      "types": [
        "./es/*.d.ts",
        "./es/*/index.d.ts"
      ],
      "import": "./es/*.mjs"
    },
    "./lib/*.cjs": {
      "types": "./lib/*.d.ts",
      "require": "./lib/*.cjs"
    },
    "./lib/*": {
      "types": [
        "./lib/*.d.ts",
        "./lib/*/index.d.ts"
      ],
      "require": "./lib/*.cjs"
    },
    "./*": "./*"
  },
  "main": "lib/index.cjs",
  "module": "es/index.mjs",
  "types": "es/index.d.ts",
  "files": [
    "CHANGELOG.md",
    "es",
    "lib"
  ],
  "engines": {
    "node": ">=24",
    "pnpm": "^10"
  },
  "scripts": {
    "clean": "rimraf es lib",
    "changelog": "elora changelog",
    "release": "elora release --registry https://npm.pkg.github.com",
    "build": "pnpm run clean && rollup --config rollup.config.ts --configPlugin @rollup/plugin-typescript",
    "prettier": "prettier --write .",
    "prepare": "husky install",
    "lint": "eslint --ext .vue,.js,.jsx,.ts,.tsx ./ --max-warnings 0",
    "lint:fix": "eslint --ext .vue,.js,jsx,.ts,.tsx ./ --max-warnings 0 --fix"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "unplugin-vue-components": "catalog:peer"
  },
  "dependencies": {
    "compare-versions": "catalog:prod",
    "local-pkg": "catalog:prod",
    "unplugin-vue-components": "catalog:peer"
  },
  "devDependencies": {
    "@elora-cloud/elora-cli": "catalog:dev",
    "@elora-cloud/eslint-config": "catalog:dev",
    "@rollup/plugin-typescript": "catalog:dev",
    "@types/node": "catalog:dev",
    "eslint": "catalog:dev",
    "fast-glob": "catalog:dev",
    "husky": "catalog:dev",
    "lint-staged": "catalog:dev",
    "postcss-scss": "catalog:dev",
    "prettier": "catalog:dev",
    "rimraf": "catalog:dev",
    "rollup": "catalog:dev",
    "rollup-plugin-dts": "catalog:dev",
    "rollup-plugin-typescript2": "catalog:dev",
    "tsx": "catalog:dev",
    "typescript": "catalog:dev"
  },
  "lint-staged": {
    "*.{ts,tsx,js,vue,sass}": "prettier --write",
    "*.{ts,tsx,js,vue}": "eslint . --fix"
  }
}
